# App
PUBLIC_SITE_URL=https://konference.animas.lv
APP_ENV=development

# Database / Supabase
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_ANON_KEY=replace_me

# Company360 - keep this server-side only
C360_API_BASE=https://api.company360.lv
C360_API_KEY=c360_xxx

# Transactional email
EMAIL_PROVIDER=resend
EMAIL_FROM="AI Reality Check <konference@animas.lv>"
RESEND_API_KEY=replace_me
EMAIL_LOGO_URL=https://konference.animas.lv/C360-logo-balts.png

# Microsoft Graph calendar invitations
MICROSOFT_TENANT_ID=replace_me
MICROSOFT_CLIENT_ID=replace_me
MICROSOFT_CLIENT_SECRET=replace_me
MICROSOFT_GRAPH_CALENDAR_USER=konference@animas.lv
MICROSOFT_GRAPH_EVENT_ID=replace_me

# Secure links / QR
TOKEN_PEPPER=replace_me
MAGIC_LINK_TTL_DAYS=90
ADMIN_API_KEY=replace_me

# Apple Wallet
APPLE_PASS_TYPE_ID=pass.lv.animas.conference
APPLE_TEAM_ID=replace_me
APPLE_PASS_CERT_PATH=./secrets/apple-pass.p12
APPLE_PASS_CERT_PASSWORD=replace_me

# Google Wallet
GOOGLE_WALLET_ISSUER_ID=replace_me
GOOGLE_WALLET_CLASS_ID=replace_me
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=./secrets/google-wallet-service-account.json
